<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- macOS-виджет живёт в песочнице; App Group даёт общий статус. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.bigboys.Vorn</string>
	</array>
	<!-- Только на macOS: LiveActivityIntent там недоступен, интент кнопки
	     выполняется в процессе виджета — ему нужны права на управление
	     туннелем. Рабочесть подхода подтверждена: виджет Happ на macOS
	     устроен ровно так же (NE-энтайтлмент + network.client у appex). -->
	<key>com.apple.developer.networking.networkextension</key>
	<array>
		<string>packet-tunnel-provider</string>
	</array>
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
